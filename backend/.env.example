# =============================================
# Procurement AI System — Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# =============================================

# --- Azure AI Foundry Configuration ---
AZURE_EXISTING_AGENT_ID=""
AZURE_ENV_NAME="your-env-name"
AZURE_LOCATION="eastus2"
AZURE_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
AZURE_AIPROJECT_ENDPOINT="https://your-resource.services.ai.azure.com/api/projects/your-project"
AZURE_EXISTING_AIPROJECT_RESOURCE_ID="/subscriptions/YOUR_SUBSCRIPTION_ID/resourceGroups/YOUR_RG/providers/Microsoft.CognitiveServices/accounts/your-resource/projects/your-project"
AZURE_EXISTING_RESOURCE_ID="/subscriptions/YOUR_SUBSCRIPTION_ID/resourceGroups/YOUR_RG/providers/Microsoft.CognitiveServices/accounts/your-resource"
AZD_ALLOW_NON_EMPTY_FOLDER=true

# --- AI Workflow Settings ---
FOUNDRY_WORKFLOW_NAME="intelligent-procurement-flow"
AZURE_AI_ENDPOINT="https://your-resource.services.ai.azure.com/api/projects/your-project"
AZURE_AI_WORKFLOW_NAME="intelligent-procurement-flow"
AZURE_AI_WORKFLOW_VERSION=1

# --- Azure SQL Database Configuration ---
# Set USE_AZURE_SQL=true for Azure SQL, false for local SQLite (development)
AZURE_SQL_SERVER="your-server.database.windows.net"
AZURE_SQL_DATABASE="procurement-db"
AZURE_SQL_USERNAME="your-sql-username"
AZURE_SQL_PASSWORD="your-sql-password"
AZURE_SQL_DRIVER="ODBC Driver 18 for SQL Server"
USE_AZURE_SQL=false
